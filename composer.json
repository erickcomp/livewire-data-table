{
    "name": "erickcomp/livewire-data-table",
    "type": "library",
    "description": "Provides a html/blade centric data table approach leveraging Livewire's reactiveness for a great UX.",
    "keywords": [
        "laravel",
        "framework",
        "livewire",
        "table",
        "data",
        "data-table"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "laravel/framework": "^12.60|^13.10",
        "livewire/livewire": "^3.6|^4.0",
        "erickcomp/laravel-raw-blade-components": "^3.0",
        "phpgt/dom": "^4.1"
    },
    "autoload": {
        "psr-4": {
            "ErickComp\\LivewireDataTable\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "extra": {
        "laravel": {
            "providers": [
                "ErickComp\\LivewireDataTable\\ServiceProvider"
            ],
            "dont-discover": []
        }
    },
    "suggest": {
        "laravie/serialize-queries": "Allows Eloquent and Database query builders to be used as data sources for data tables."
    },
    "require-dev": {
        "pestphp/pest": "^4.7",
        "orchestra/testbench": "^10.0|^11.0",
        "larastan/larastan": "^3.0"
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "analyse": "vendor/bin/phpstan analyse --memory-limit=512M"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
